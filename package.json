{
  "name": "apollon2",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "workspaces": [
    "apps/*",
    "library"
  ],
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "lint": "yarn workspaces foreach -A run lint",
    "watch": "yarn workspaces foreach -A run watch",
    "start": "yarn workspace webapp dev",
    "slib": "yarn workspace @apollon/library dev",
    "blib": "yarn workspace @apollon/library build",
    "lint:w": "npx eslint .",
    "lint:fix": "yarn workspaces foreach -A -p run lint:fix",
    "prettier": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
    "prettier:fix": "prettier --write \"**/*.+(js|ts|json)\"",
    "start:server": "yarn workspace server start",
    "postinstall": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.16.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "3.4.2",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.17.0",
    "vite": "^6.0.3",
    "vite-plugin-css": "^1.0.4"
  },
  "packageManager": "yarn@4.5.3",
  "lint-staged": {
    "**/*.{ts,tsx,js,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "resolutions": {
    "typescript": "^5.7.2"
  }
}
